# agentic-publishing-pipeline — environment variables (example)
#
# Copy this file to `.env` for local runs in `live` mode. The
# `offline-fixture` and `dry-run` modes do not require any of these
# variables; CI never reads `.env`.
#
# DO NOT commit `.env`. The `.gitignore` rule keeps it untracked.

# --- LLM provider ---
# Logical provider id ("anthropic", "openai", "fixture"). The default
# offline-fixture provider does not consult this value.
APP_LLM_PROVIDER=fixture

# Logical model class, preserved in request metadata.
APP_LLM_MODEL_CLASS=research

# Concrete live OpenAI model id used when APP_LLM_PROVIDER=openai.
APP_LLM_MODEL_ID=gpt-4.1-mini

# Anthropic-style API key (only required in `live` mode against
# Anthropic). Treated as a secret-shaped variable and recorded in the
# configuration snapshot as "***present***" or "***absent***".
ANTHROPIC_API_KEY=

# OpenAI-style API key (alternative provider).
OPENAI_API_KEY=

# --- Search / metadata verification ---
# Optional external search provider id. The offline-fixture path does
# not consult this value. Real adapters arrive in Phase 7 when the
# Bibliography Agent's source-verification step is implemented.
APP_SEARCH_PROVIDER=fixture
APP_SEARCH_API_KEY=

# --- Budget / policy (API Gatekeeper) ---
# Maximum number of provider requests per run; the Gatekeeper raises
# GatekeeperRejection on exhaustion (FR-44).
APP_GATEKEEPER_MAX_REQUESTS=64
# Maximum estimated cost (USD) per run; soft ceiling — see ADR-0004.
APP_GATEKEEPER_MAX_COST_USD=2.50
# Per-call timeout seconds.
APP_GATEKEEPER_TIMEOUT_SECONDS=30

# --- Output / run roots ---
# Override the default results root (`./results`). Optional; the
# absolute path is resolved at run start.
APP_RESULTS_ROOT=
